; Dungeon Veil native Godot/Xogot port scaffold
; Open artifacts/dungeon-rpg as the project folder in Xogot.

config_version=5

[application]
config/name="Dungeon Veil — Xogot Port"
run/main_scene="res://godot/main.tscn"
config/features=PackedStringArray("4.4", "Mobile")

[display/window]
size/viewport_width=1179
size/viewport_height=2556
size/window_width_override=393
size/window_height_override=852
stretch/mode="canvas_items"
handheld/orientation=1

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
anti_aliasing/quality/msaa_3d=0
anti_aliasing/quality/screen_space_aa=0
shadows/directional_shadow/size=2048

[debug]
settings/fps/force_fps=0
